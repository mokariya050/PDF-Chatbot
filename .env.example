# ============================================================
# AI PDF Chatbot - Environment Variables
# ============================================================
# Setup:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your real values below
#   3. NEVER commit the .env file to Git
# ============================================================

# -----------------------------------------------------------
# Google Gemini API Key (REQUIRED)
# -----------------------------------------------------------
# Get your free key at: https://aistudio.google.com/apikey
# Used to send prompts to the Gemini LLM for answer generation.
GOOGLE_API_KEY=your_google_api_key_here

# -----------------------------------------------------------
# Model Configuration (OPTIONAL - defaults exist in config.py)
# -----------------------------------------------------------
# LLM model name. Options: gemini-2.5-flash, gemini-2.5-pro
# LLM_MODEL_NAME=gemini-2.5-flash

# Temperature controls randomness: 0.0 = deterministic, 1.0 = creative.
# For a factual Q&A chatbot, keep this low (0.1-0.3).
# LLM_TEMPERATURE=0.2

# -----------------------------------------------------------
# Embedding Configuration (OPTIONAL - defaults exist in config.py)
# -----------------------------------------------------------
# HuggingFace model for generating text embeddings.
# Runs locally on your machine — no API key needed.
# EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# -----------------------------------------------------------
# Chunking Configuration (OPTIONAL - defaults exist in config.py)
# -----------------------------------------------------------
# Number of characters per text chunk.
# Larger = more context per chunk, but less precise retrieval.
# CHUNK_SIZE=1000

# Characters of overlap between consecutive chunks.
# Prevents losing context at chunk boundaries.
# CHUNK_OVERLAP=200

# -----------------------------------------------------------
# Retrieval Configuration (OPTIONAL - defaults exist in config.py)
# -----------------------------------------------------------
# Number of most relevant chunks to retrieve per query.
# Higher = more context for the LLM, but more noise.
# TOP_K=4

# -----------------------------------------------------------
# Database Configuration (REQUIRED)
# -----------------------------------------------------------
# PostgreSQL connection URI from Supabase.
# Get your free database at: https://supabase.com
# Find the URI in: Project Settings → Database → Connection String → URI
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
#
# For local development with PostgreSQL:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/pdf_chatbot
DATABASE_URL=your_database_url_here

# -----------------------------------------------------------
# JWT Authentication (REQUIRED)
# -----------------------------------------------------------
# Secret key for signing JWT tokens. Use a long, random string.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_jwt_secret_key_here

# JWT token expiry time in hours (default: 24 hours).
# JWT_EXPIRY_HOURS=24

# -----------------------------------------------------------
# Frontend URL (REQUIRED for deployment)
# -----------------------------------------------------------
# The URL where your frontend is deployed (for CORS).
# Example: https://your-app.vercel.app
# Leave empty for local development (localhost is allowed by default).
FRONTEND_URL=
